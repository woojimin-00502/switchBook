{
  "name": "switchbook",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @switchbook/web",
    "dev:api": "npm run start:dev -w @switchbook/api",
    "dev": "npm-run-all -p dev:api dev:web",
    "build": "npm run build -w @switchbook/web && npm run build -w @switchbook/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
